<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Add "Import from ACT" button to partner form -->
    <record id="view_partner_form_act_import" model="ir.ui.view">
        <field name="name">res.partner.form.act.import</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <!-- Import button at the top -->
            <xpath expr="//div[hasclass('oe_title')]" position="before">
                <div class="float-end">
                    <button name="action_open_act_import"
                            string="Import from ACT"
                            type="object"
                            class="btn-secondary"
                            icon="fa-download"/>
                </div>
            </xpath>
            <!-- ACT tab at the bottom of the notebook -->
            <xpath expr="//notebook" position="inside">
                <page string="ACT" name="act_info"
                      invisible="not act_contact_id and not act_company_id">
                    <group>
                        <group string="ACT Identifiers">
                            <field name="act_contact_id" readonly="1"/>
                            <field name="act_company_id" readonly="1"/>
                        </group>
                        <group string="Sync Info">
                            <field name="act_last_sync" readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
