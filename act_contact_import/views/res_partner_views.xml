<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_partner_form_act_import" model="ir.ui.view">
        <field name="name">res.partner.form.act.import</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <!-- "Sync with ACT" button — widget so it doesn't force a save -->
            <xpath expr="//div[hasclass('oe_title')]" position="before">
                <div class="float-end">
                    <widget name="sync_with_act_button"/>
                </div>
            </xpath>
            <!-- Blacklist button next to email -->
            <xpath expr="//field[@name='email']" position="after">
                <button name="action_blacklist_email" type="object"
                        class="btn-link text-danger p-0 ms-1"
                        icon="fa-ban"
                        title="Blacklist this email"
                        invisible="not email or is_blacklisted"/>
                <span class="text-danger ms-1"
                      invisible="not is_blacklisted">
                    <i class="fa fa-ban"/> Blacklisted
                </span>
            </xpath>
            <!-- Make company_id editable — Misc group under Sales & Purchase -->
            <xpath expr="//group[@name='misc']/field[@name='company_id']" position="attributes">
                <attribute name="readonly">0</attribute>
                <attribute name="force_save">1</attribute>
            </xpath>
            <!-- ACT tab at the bottom -->
            <xpath expr="//notebook" position="inside">
                <page string="ACT" name="act_info"
                      invisible="not act_contact_id and not act_company_id">
                    <group>
                        <group string="ACT Identifiers">
                            <field name="act_contact_id" readonly="1"/>
                            <field name="act_company_id" readonly="1"/>
                        </group>
                        <group string="Sync Info">
                            <field name="act_last_sync" readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
