<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================================
         IMPORT wizard  (Contacts list page → create NEW records)
         ============================================================ -->

    <record id="act_import_wizard_form" model="ir.ui.view">
        <field name="name">act.import.wizard.form</field>
        <field name="model">act.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import from ACT">
                <field name="state" invisible="1"/>

                <!-- SEARCH -->
                <div invisible="state != 'search'">
                    <group>
                        <field name="search_term"
                               placeholder="Search companies and contacts in ACT..."/>
                    </group>
                    <footer>
                        <button name="action_search" string="Search ACT"
                                type="object" class="btn-primary" icon="fa-search"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </div>

                <!-- RESULTS (companies + individuals combined) -->
                <div invisible="state != 'results'">
                    <div class="alert alert-info" role="alert">
                        <strong>Results for: </strong>
                        <field name="search_term" readonly="1" nolabel="1"/>
                        <span> — "Import" creates a new contact. For companies, "View Contacts" lets you bulk-import people.</span>
                    </div>
                    <field name="result_ids" nolabel="1">
                        <list>
                            <field name="record_type" string="Type"/>
                            <field name="name" string="Name"/>
                            <field name="function" string="Job Title" optional="show"/>
                            <field name="company_name_act" string="Company" optional="show"/>
                            <field name="contact_count" string="# Contacts" optional="show"/>
                            <field name="city" optional="show"/>
                            <field name="state_name" string="State" optional="show"/>
                            <field name="phone" optional="show"/>
                            <field name="email" optional="show"/>
                            <button name="action_view_contacts" string="View Contacts"
                                    type="object" class="btn-info btn-sm"
                                    invisible="record_type != 'company'"
                                    icon="fa-users"/>
                            <button name="action_import" string="Import"
                                    type="object" class="btn-primary btn-sm"
                                    icon="fa-download"/>
                        </list>
                    </field>
                    <footer>
                        <button name="action_back" string="&#8592; New Search"
                                type="object" class="btn-secondary"/>
                        <button string="Close" class="btn-secondary" special="cancel"/>
                    </footer>
                </div>

                <!-- COMPANY CONTACTS (drill-down with checkboxes) -->
                <div invisible="state != 'contacts'">
                    <div class="alert alert-info" role="alert">
                        <strong>Contacts for: </strong>
                        <field name="company_line_id" readonly="1" nolabel="1"
                               options="{'no_open': True}"/>
                        <span> — Check the ones you want, then hit "Import Selected".
                        The company will be auto-imported too.</span>
                    </div>
                    <field name="contact_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="selected" string="Import?"
                                   readonly="already_imported"/>
                            <field name="already_imported" string="In Odoo"
                                   widget="boolean"/>
                            <field name="name" string="Name" readonly="1"/>
                            <field name="function" string="Job Title" readonly="1"
                                   optional="show"/>
                            <field name="city" readonly="1" optional="show"/>
                            <field name="state_name" string="State" readonly="1"
                                   optional="show"/>
                            <field name="phone" readonly="1" optional="show"/>
                            <field name="email" readonly="1" optional="show"/>
                        </list>
                    </field>
                    <footer>
                        <button name="action_import_selected_contacts"
                                string="Import Selected"
                                type="object" class="btn-primary" icon="fa-download"/>
                        <button name="action_back_to_results"
                                string="&#8592; Back to Results"
                                type="object" class="btn-secondary"/>
                        <button string="Close" class="btn-secondary" special="cancel"/>
                    </footer>
                </div>
            </form>
        </field>
    </record>

    <record id="action_act_import_wizard" model="ir.actions.act_window">
        <field name="name">Import from ACT</field>
        <field name="res_model">act.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu item under Contacts -->
    <menuitem id="menu_act_import"
              name="Import from ACT"
              parent="contacts.menu_contacts"
              action="action_act_import_wizard"
              sequence="20"/>


    <!-- ============================================================
         SYNC wizard  (partner FORM page → UPDATE existing record)
         ============================================================ -->

    <record id="act_sync_wizard_form" model="ir.ui.view">
        <field name="name">act.sync.wizard.form</field>
        <field name="model">act.sync.wizard</field>
        <field name="arch" type="xml">
            <form string="Sync with ACT">
                <field name="state" invisible="1"/>
                <field name="partner_id" invisible="1"/>
                <field name="partner_is_company" invisible="1"/>
                <field name="selected_line_id" invisible="1"/>

                <!-- SEARCH -->
                <div invisible="state != 'search'">
                    <div class="alert alert-warning" role="alert">
                        <strong>Updating: </strong>
                        <field name="partner_name" readonly="1" nolabel="1"/>
                        <span> — Find the matching ACT record to sync fields into this partner.</span>
                    </div>
                    <group>
                        <field name="search_term"
                               placeholder="Search ACT..."/>
                    </group>
                    <footer>
                        <button name="action_search" string="Search ACT"
                                type="object" class="btn-primary" icon="fa-search"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </div>

                <!-- RESULTS -->
                <div invisible="state != 'results'">
                    <div class="alert alert-warning" role="alert">
                        <strong>Syncing: </strong>
                        <field name="partner_name" readonly="1" nolabel="1"/>
                        <span> — Click "Preview" to see what would change before applying.</span>
                    </div>
                    <field name="result_ids" nolabel="1">
                        <list>
                            <field name="name" string="Name"/>
                            <field name="function" string="Job Title"
                                   invisible="parent.partner_is_company"
                                   optional="show"/>
                            <field name="company_name_act" string="Company"
                                   invisible="parent.partner_is_company"
                                   optional="show"/>
                            <field name="industry"
                                   invisible="not parent.partner_is_company"
                                   optional="show"/>
                            <field name="city" optional="show"/>
                            <field name="state_name" string="State" optional="show"/>
                            <field name="phone" optional="show"/>
                            <field name="email" optional="show"/>
                            <button name="action_preview_sync" string="Preview"
                                    type="object" class="btn-warning btn-sm"
                                    icon="fa-eye"/>
                        </list>
                    </field>
                    <footer>
                        <button name="action_back" string="&#8592; New Search"
                                type="object" class="btn-secondary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </div>

                <!-- PREVIEW DIFF -->
                <div invisible="state != 'preview'">
                    <div class="alert alert-info" role="alert">
                        <strong>Review changes for: </strong>
                        <field name="partner_name" readonly="1" nolabel="1"/>
                        <span> — Check the fields you want to update, then click "Apply".</span>
                    </div>
                    <field name="diff_ids" nolabel="1">
                        <list editable="bottom"
                              decoration-success="is_new"
                              decoration-warning="is_change and not is_new"
                              decoration-muted="not is_change and not is_new">
                            <field name="apply" string="Apply"
                                   readonly="not is_change and not is_new"/>
                            <field name="field_label" string="Field" readonly="1"/>
                            <field name="current_value" string="Current (Odoo)" readonly="1"/>
                            <field name="new_value" string="From ACT" readonly="1"/>
                            <field name="is_change" column_invisible="1"/>
                            <field name="is_new" column_invisible="1"/>
                            <field name="field_name" column_invisible="1"/>
                            <field name="new_value_id" column_invisible="1"/>
                        </list>
                    </field>
                    <footer>
                        <button name="action_apply_sync"
                                string="Apply Selected Changes"
                                type="object" class="btn-primary" icon="fa-check"/>
                        <button name="action_back_to_results"
                                string="&#8592; Back to Results"
                                type="object" class="btn-secondary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </div>
            </form>
        </field>
    </record>

</odoo>
