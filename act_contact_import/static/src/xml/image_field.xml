<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="web.ImageField" t-inherit="web.ImageField" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('opacity-trigger-hover')]" position="inside">
            <div t-if="!props.readonly and fieldType !== 'many2one'"
                 class="position-absolute top-0 end-0 opacity-0 opacity-100-hover"
                 t-att-style="sizeStyle">
                <button
                    class="btn btn-light border-0 rounded-circle m-1 p-1"
                    data-tooltip="Paste image URL from clipboard"
                    aria-label="Paste from clipboard"
                    t-on-click="onClipboardPaste">
                    <i class="fa fa-clipboard fa-fw"/>
                </button>
            </div>
        </xpath>
    </t>

</templates>
